    "class": {
      "prefix": "class",
      "body": [
        "class ${1:ClassName} {",
        "public:",
        "\t${1:ClassName}();",
        "\t~${1:ClassName}();",
        "\t",
        "private:",
        "\t${2:// members}",
        "};"
      ],
      "description": "Class definition"
    },
    "class_full": {
      "prefix": "classf",
      "body": [
        "class ${1:ClassName} {",
        "public:",
        "\t${1:ClassName}();",
        "\t${1:ClassName}(const ${1:ClassName}& other);",
        "\t${1:ClassName}& operator=(const ${1:ClassName}& other);",
        "\t~${1:ClassName}();",
        "\t",
        "private:",
        "\t${2:// members}",
        "};"
      ],
      "description": "Class with rule of three"
    },
