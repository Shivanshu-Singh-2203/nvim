        "\t${1:// code}",
        "} while (${2:condition});"
      ],
      "description": "Do-while loop"
    },
    "switch": {
      "prefix": "switch",
      "body": [
        "switch (${1:expression}) {",
        "\tcase ${2:value}:",
        "\t\t${3:// code}",
        "\t\tbreak;",
        "\tdefault:",
        "\t\t${4:// code}",
        "\t\tbreak;",
        "}"
      ],
      "description": "Switch statement"
    },
    "case": {
      "prefix": "case",
      "body": [
        "case ${1:value}:",
        "\t${2:// code}",
        "\tbreak;"
      ],
      "description": "Case statement"
    },
    "struct": {
      "prefix": "struct",
      "body": [
        "struct ${1:name} {",
        "\t${2:// members}",
        "};"
