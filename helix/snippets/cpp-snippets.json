        "",
        "#endif // ${1:HEADER}_H"
      ],
      "description": "Header guard"
    },
    "pragma_once": {
      "prefix": "pragma",
      "body": "#pragma once",
      "description": "Pragma once"
    },
    "printf": {
      "prefix": "pf",
