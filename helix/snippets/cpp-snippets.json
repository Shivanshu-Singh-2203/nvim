      "description": "Typedef struct"
    },
    "enum": {
      "prefix": "enum",
      "body": [
        "enum ${1:name} {",
        "\t${2:// values}",
        "};"
      ],
      "description": "Enum definition"
    },
    "union": {
      "prefix": "union",
      "body": [
        "union ${1:name} {",
        "\t${2:// members}",
        "};"
      ],
