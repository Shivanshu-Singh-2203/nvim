      "prefix": "func",
      "body": [
        "${1:void} ${2:function_name}(${3:void}) {",
        "\t${4:// code}",
        "}"
      ],
      "description": "Function definition"
    },
    "malloc": {
      "prefix": "malloc",
      "body": "${1:type} *${2:ptr} = (${1:type} *)malloc(${3:size} * sizeof(${1:type}));",
      "description": "Malloc allocation"
    },
    "calloc": {
      "prefix": "calloc",
      "body": "${1:type} *${2:ptr} = (${1:type} *)calloc(${3:count}, sizeof(${1:type}));",
      "description": "Calloc allocation"
    },
    "realloc": {
      "prefix": "realloc",
      "body": "${1:ptr} = (${2:type} *)realloc(${1:ptr}, ${3:new_size} * sizeof(${2:type}));",
      "description": "Realloc"
    },
    "free": {
      "prefix": "free",
      "body": "free(${1:ptr});",
      "description": "Free memory"
    },
    "fopen": {
      "prefix": "fopen",
      "body": "FILE *${1:fp} = fopen(\"${2:filename}\", \"${3:r}\");",
      "description": "File open"
    },
    "fclose": {
      "prefix": "fclose",
      "body": "fclose(${1:fp});",
      "description": "File close"
    },
    "comment_block": {
      "prefix": "/*",
      "body": [
