      "description": "Printf statement"
    },
    "fprintf": {
      "prefix": "fpf",
      "body": "fprintf(${1:stderr}, \"${2:%s}\\n\", ${3:args});",
      "description": "Fprintf statement"
    },
    "scanf": {
      "prefix": "sf",
      "body": "scanf(\"${1:%d}\", &${2:var});",
      "description": "Scanf statement"
    },
    "if": {
      "prefix": "if",
      "body": [
        "if (${1:condition}) {",
        "\t${2:// code}",
        "}"
      ],
      "description": "If statement"
    },
    "else": {
      "prefix": "else",
      "body": [
        "else {",
        "\t${1:// code}",
        "}"
      ],
      "description": "Else statement"
    },
    "elif": {
      "prefix": "elif",
      "body": [
        "else if (${1:condition}) {",
        "\t${2:// code}",
        "}"
      ],
      "description": "Else if statement"
    },
    "for": {
      "prefix": "for",
      "body": [
        "for (${1:int i = 0}; ${2:i < n}; ${3:i++}) {",
        "\t${4:// code}",
        "}"
      ],
      "description": "For loop"
    },
    "fori": {
      "prefix": "fori",
      "body": [
        "for (int ${1:i} = 0; ${1:i} < ${2:n}; ${1:i}++) {",
        "\t${3:// code}",
        "}"
      ],
      "description": "For loop with int i"
